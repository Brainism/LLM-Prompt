{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "result_log",
  "type": "object",
  "additionalProperties": true,

  "anyOf": [
    { "required": ["id"] },
    { "required": ["item_id"] },
    { "required": ["example_id"] }
  ],
  "allOf": [
    {
      "anyOf": [
        { "required": ["output"] },
        { "required": ["text"] },
        { "required": ["generation"] },
        { "required": ["answer"] },
        { "required": ["content"] },
        { "required": ["response"] }
      ]
    },
    { "required": ["latency_ms"] }
  ],

  "properties": {
    "id":         { "type": "string" },
    "item_id":    { "type": "string" },
    "example_id": { "type": "string" },

    "run_id":   { "type": "string" },
    "model":    { "type": "string" },
    "mode":     { "type": "string", "enum": ["general", "instructed"] },
    "provider": { "type": "string" },

    "input":   { "type": "string" },

    "output":    { "type": "string" },
    "text":      { "type": "string" },
    "generation":{ "type": "string" },
    "answer":    { "type": "string" },
    "content":   { "type": "string" },
    "response":  { "type": "string" },

    "latency_ms": { "type": "number", "minimum": 0 },
    "cost_usd":   { "type": "number", "minimum": 0 },

    "tok_in":  { "type": "integer", "minimum": 0 },
    "tok_out": { "type": "integer", "minimum": 0 },
    "len_in":  { "type": "integer", "minimum": 0 },
    "len_out": { "type": "integer", "minimum": 0 },

    "valid_json":       { "type": "boolean" },
    "forbid_violation": { "type": "boolean" },
    "length_ok":        { "type": "boolean" },
    "bullet_ok":        { "type": "boolean" },

    "timestamp": { "type": "string" }
  }
}