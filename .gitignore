(
echo .venv/
echo __pycache__/
echo *.pyc
echo logs/
echo *.out
echo *.log
echo *.tmp
echo *.bak
echo results/raw/
echo results/aligned/
echo results/figures/
echo results/quantitative/*.json
echo results/quantitative/*.png
echo !results/quantitative/
echo !results/quantitative/stats_summary.csv
echo prompts/prompts_smoke.csv
echo .DS_Store
echo Thumbs.db
echo .ipynb_checkpoints/
) > .gitignore

(
  echo __pycache__/
  echo *.pyc
  echo .venv/
  echo logs/
  echo dist/*.zip
  echo results/raw/*.jsonl
  echo !results/raw_patched/*.jsonl
) >> .gitignore.venv/
